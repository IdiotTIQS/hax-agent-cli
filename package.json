{
  "name": "hax-agent-cli",
  "version": "1.6.0",
  "description": "A professional AI coding assistant with Claude-like CLI experience. Explore codebases, read/write files, execute shell commands, and coordinate agent teams.",
  "main": "src/index.js",
  "bin": {
    "hax-agent": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "desktop:dev": "node desktop/scripts/dev.js",
    "desktop:start": "node desktop/scripts/start.js",
    "desktop:build": "vite build --config desktop/renderer/vite.config.js",
    "auth:team": "node src/cli.js team auth-refactor",
    "typecheck": "tsc --noEmit",
    "lint": "node scripts/lint.js && tsc --noEmit",
    "test": "node scripts/run-tests.js",
    "test:desktop": "npm run desktop:build && node scripts/run-tests.js test/desktop",
    "prepublishOnly": "npm test"
  },
  "files": [
    "src/**/*.js",
    "desktop/**/*.js",
    "desktop/**/*.vue",
    "desktop/**/*.css",
    "desktop/**/*.mjs",
    "desktop/**/*.html",
    "desktop/**/*.json",
    "scripts/**/*.js",
    "README.md",
    "README.en.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IdiotTIQS/hax-agent-cli.git"
  },
  "bugs": {
    "url": "https://github.com/IdiotTIQS/hax-agent-cli/issues"
  },
  "homepage": "https://github.com/IdiotTIQS/hax-agent-cli#readme",
  "keywords": [
    "ai",
    "agent",
    "cli",
    "coding-assistant",
    "claude",
    "openai",
    "google",
    "gemini",
    "code-refactor",
    "code-exploration",
    "shell",
    "anthropic"
  ],
  "author": "IdiotTIQS",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@google/generative-ai": "^0.24.1",
    "dompurify": "^3.4.2",
    "markdown-it": "^14.1.1",
    "openai": "^6.35.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.10",
    "electron": "^37.5.1",
    "jsdom": "^24.1.3",
    "playwright-core": "^1.59.1",
    "typescript": "^6.0.3",
    "vite": "^6.3.6",
    "vue": "^3.5.22"
  },
  "optionalDependencies": {
    "node-notifier": "^10.0.0",
    "tiktoken": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
