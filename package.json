{
  "name": "hax-agent-cli",
  "version": "1.3.4",
  "description": "A professional AI coding assistant with Claude-like CLI experience. Explore codebases, read/write files, execute shell commands, and coordinate agent teams.",
  "main": "src/index.js",
  "bin": {
    "hax-agent": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "auth:team": "node src/cli.js team auth-refactor",
