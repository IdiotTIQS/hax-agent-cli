{
  "name": "hax-agent-cli",
  "version": "1.3.8",
  "description": "A professional AI coding assistant with Claude-like CLI experience. Explore codebases, read/write files, execute shell commands, and coordinate agent teams.",
  "main": "src/index.js",
  "bin": {
    "hax-agent": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "desktop:dev": "node desktop/scripts/dev.js",
    "desktop:start": "electron desktop/main/index.js",
    "desktop:build": "vite build --config desktop/renderer/vite.config.js",
    "auth:team": "node src/cli.js team auth-refactor",
    "test": "node --test test/*.test.js",
    "prepublishOnly": "npm test"
  },
  "files": [
    "src/**/*.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IdiotTIQS/hax-agent-cli.git"
  },
  "bugs": {
    "url": "https://github.com/IdiotTIQS/hax-agent-cli/issues"
  },
  "homepage": "https://github.com/IdiotTIQS/hax-agent-cli#readme",
  "keywords": [
    "ai",
    "agent",
    "cli",
    "coding-assistant",
    "claude",
    "openai",
    "google",
    "gemini",
    "code-refactor",
    "code-exploration",
    "shell",
    "anthropic"
  ],
  "author": "IdiotTIQS",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@google/generative-ai": "^0.24.1",
    "openai": "^6.35.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "electron": "^37.5.1",
    "vite": "^6.3.6",
    "vue": "^3.5.22"
  },
  "engines": {
    "node": ">=18"
  }
}
