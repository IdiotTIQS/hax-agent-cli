    "prepublishOnly": "npm test"
  },
  "files": [
    "src/**/*.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IdiotTIQS/hax-agent-cli.git"
  },
  "bugs": {
    "url": "https://github.com/IdiotTIQS/hax-agent-cli/issues"
  },
  "homepage": "https://github.com/IdiotTIQS/hax-agent-cli#readme",
  "keywords": [
    "ai",
    "agent",
    "cli",
    "coding-assistant",
    "claude",
    "openai",
    "google",
    "gemini",
    "code-refactor",
    "code-exploration",
    "shell",
    "anthropic"
  ],
  "author": "IdiotTIQS",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@google/generative-ai": "^0.24.1",
    "openai": "^6.35.0"
  },
  "engines": {
    "node": ">=18"
  }
}
