# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.css text eol=lf
*.html text eol=lf
*.vue text eol=lf
*.mjs text eol=lf

# Scripts
*.sh text eol=lf

# Windows-specific
*.bat text eol=crlf
*.cmd text eol=crlf
