{
  // 构建配置（区别于根 tsconfig.json 的 noEmit 护栏配置）。
  // 全仓已迁移为 TypeScript + ESM（NodeNext）。strict 全开。
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],

    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "declaration": false,

    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "desktop",
    "dist",
    "test"
  ]
}
